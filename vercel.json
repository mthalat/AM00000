{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public"
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
